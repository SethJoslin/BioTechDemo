params {
  reads = "./data/*_R{1,2}.fastq.gz"
  outdir = "./results"
  workdir = "./work"
  threads = 4
  memory = "8.GB"
  sample = "demo"
  s3_bucket = "s3://your-bucket/openbioops"
}

process {
  executor = 'k8s'
  container = 'yourrepo/nextflow-base:latest'
  withName: quant {
    cpus = 4
    memory = '16.GB'
  }
}

k8s {
  namespace = 'default'
}

profiles {
  k8s_local {
    process {
      executor = 'k8s'
      container = 'openbioops/feature-extract:local'
      cpus = 1
      memory = '2.GB'
      podOptions = { it.spec.containers[0].imagePullPolicy = 'IfNotPresent' }
    }
    k8s.namespace = 'default'
    report.overwrite = true
  }
}